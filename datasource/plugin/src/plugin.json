{
  "$schema": "https://raw.githubusercontent.com/grafana/grafana/master/docs/sources/developers/plugins/plugin.schema.json",
  "type": "datasource",
  "name": "NGSI-LD datasource",
  "id": "ngsild-grafana-datasource",
  "metrics": true,
  "info": {
    "description": "A datasource plugin for NGSI-LD context brokers",
    "author": {
      "name": "Christoph Nölle",
      "url": "https://www.bfi.de"
    },
    "keywords": ["ngsild", "fiware", "context"],
    "logos": {
      "small": "img/logo.svg",
      "large": "img/logo.svg"
    },
    "links": [
      {
        "name": "Website",
        "url": "https://github.com/bfi-de/ngsild-grafana-datasource"
      },
      {
        "name": "License",
        "url": "https://github.com/bfi-de/ngsild-grafana-datasource/blob/master/LICENSE"
      }
    ],
    "screenshots": [],
    "version": "%VERSION%",
    "updated": "%TODAY%"
  },
  "routes":[
    {
      "path": "ngsi-ld",
      "url": "{{ .Url }}/ngsi-ld",
      "tokenAuth": {
        "url": "{{ .JsonData.tokenUrl }}",
        "params": {
          "grant_type": "client_credentials",
          "client_id": "{{ if .SecureJsonData.clientId }}{{ .SecureJsonData.clientId }}{{ else }}{{ .JsonData.clientId }}{{ end }}",
          "client_secret": "{{ if .SecureJsonData.clientSecret }}{{ .SecureJsonData.clientSecret }}{{ else }}{{ .JsonData.clientSecret }}{{ end }}"
        }
      }
    },
    {
      "path": "version",
      "url": "{{ .Url }}/version",
      "tokenAuth": {
        "url": "{{ .JsonData.tokenUrl }}",
        "params": {
          "grant_type": "client_credentials",
          "client_id": "{{ if .SecureJsonData.clientId }}{{ .SecureJsonData.clientId }}{{ else }}{{ .JsonData.clientId }}{{ end }}",
          "client_secret": "{{ if .SecureJsonData.clientSecret }}{{ .SecureJsonData.clientSecret }}{{ else }}{{ .JsonData.clientSecret }}{{ end }}"
        }
      }
    }
  ],
  "dependencies": {
    "grafanaDependency": ">=7.0.0",
    "plugins": []
  }
}